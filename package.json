{
  "name": "cyberhack-typing-game",
  "version": "1.1.0",
  "description": "Cyberpunk typing game - Programmer vs Rogue AI",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node copy-legacy.cjs",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html}\"",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}